
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User account details and career preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "targetRole": { "type": "string" },
        "industry": { "type": "string" },
        "atsScore": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "ResumeAnalysis": {
      "title": "ResumeAnalysis",
      "description": "Historical resume analysis results",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string" },
        "score": { "type": "number" },
        "suggestions": { "type": "array" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Storage for user profiles"
    },
    "/users/{userId}/analyses/{analysisId}": {
      "schema": "ResumeAnalysis",
      "description": "History of resume analyses"
    }
  }
}
